[access]
	inheritFrom = GerritForge/gerrit-enterprise-projects
[submit]
[project]
	description = Plugin to collect Git repository metrics
[access "refs/*"]
	owner = group GerritForge-git-repo-metrics
	owner = group user/Luca Milanesio (lucamilanesio)
	label-Code-Review = -2..+2 group GerritForge-git-repo-metrics
	label-Verified = -1..+1 group GerritForge-git-repo-metrics
	push = group user/Luca Milanesio (lucamilanesio)
	rebase = group GerritForge-git-repo-metrics
	removeReviewer = group GerritForge-git-repo-metrics
	submit = group GerritForge-git-repo-metrics
[access "refs/tags/*"]
	push = group user/Luca Milanesio (lucamilanesio)
	push = +force group user/Luca Milanesio (lucamilanesio)
